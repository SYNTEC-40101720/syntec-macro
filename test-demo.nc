%@MACRO

// ============================================================
// syntec-macro v2.6.1 插件功能验证测试文件
// 基于《新代控制器技术参考手册》函数表修订
// 涵盖：变量系统、控制流、运算符、函数、机器人指令、G/M码
// ============================================================

// --- 1. 变量系统 ---
// 1.1 区域变量 # (直接赋值)
#1 := 100;
#2 := 200;
#26 := 300;

// 1.2 公用变量 @ (直接赋值)
@1 := 500;
@1000 := 600;
@10000 := 700;

// 1.3 间接赋值 (中括号语法)
#3 := 123;
@[#3] := 567;
@[#3 + 7] := 890;

// 1.4 App 专用变量 AR / MAR
AR1 := 789;
MAR1 := 789;
AR[#3] := 789;
MAR[#3] := 789;

// 1.5 系统变量
#1000 := 1;
#1002 := 17;
#1004 := 90;
#1040 := 1;
#1046 := 1000;

// 1.6 轴群辨识符号
$1;
$2;
$3;
$4;

// --- 2. 控制流 ---
// 2.1 IF / ELSEIF / ELSE
IF #1 > 50 THEN
  #10 := 1;
ELSEIF #1 > 20 THEN
  #10 := 2;
ELSE
  #10 := 3;
END_IF;

// 2.2 FOR 循环 (带 BY 步进)
FOR #1 := 1 TO 10 BY 2 DO
  #2 := #2 + #1;
END_FOR;

// 2.3 WHILE 循环
#5 := 0;
WHILE #5 < 5 DO
  #5 := #5 + 1;
END_WHILE;

// 2.4 REPEAT / UNTIL 循环
#6 := 0;
REPEAT
  #6 := #6 + 1;
  IF #6 > 3 THEN
    EXIT;
  END_IF;
UNTIL #6 >= 5
END_REPEAT;

// 2.5 CASE 分支 (冒号语法 + ELSE)
#10 := 2;
CASE #10 OF
  1: #11 := 100;
  2: #11 := 200;
  3: #11 := 300;
  ELSE: #11 := 0;
END_CASE;

// 2.6 CASE 多值分支
CASE #10 OF
  1, 2: #12 := 10;
  3, 4: #12 := 20;
  ELSE: #12 := 0;
END_CASE;

// 2.7 短形式结束标记
IF #1 = 100 THEN
  #13 := 1;
ENDIF;

FOR #1 := 1 TO 5 DO
  #14 := #1;
ENDFOR;

WHILE #1 > 0 DO
  #1 := #1 - 1;
ENDWHILE;

// 2.8 嵌套 (多层)
IF #1 > 0 THEN
  IF #2 > 0 THEN
    IF #3 > 0 THEN
      #15 := 1;
    END_IF;
  END_IF;
END_IF;

// --- 3. GOTO 跳转 ---
N100;
GOTO 200;

N200;
#20 := 1;

// --- 4. 运算符 ---
// 4.1 算术运算符
#30 := 1 + 2;
#31 := 10 - 3;
#32 := 4 * 5;
#33 := 20 / 4;
#34 := 100 MOD 7;

// 4.2 整数除法陷阱
#35 := 1 / 2;
#36 := 1 / 2.0;
#37 := 1. / 2;

// 4.3 比较运算符
IF #1 > 50 THEN
  #40 := 1;
END_IF;
IF #1 >= 100 THEN
  #41 := 1;
END_IF;
IF #1 < 200 THEN
  #42 := 1;
END_IF;
IF #1 <= 100 THEN
  #43 := 1;
END_IF;
IF #1 = 100 THEN
  #44 := 1;
END_IF;
IF #1 <> 200 THEN
  #45 := 1;
END_IF;

// 4.4 逻辑运算符
IF (#1 > 10) & (#2 < 50) THEN
  #46 := 1;
END_IF;
IF (#1 = 100) AND (#2 = 200) THEN
  #47 := 1;
END_IF;
IF (#1 > 0) OR (#2 > 0) THEN
  #48 := 1;
END_IF;
IF NOT (#1 = 0) THEN
  #49 := 1;
END_IF;
IF (#1 > 0) XOR (#2 > 0) THEN
  #50 := 1;
END_IF;

// --- 5. 数学函数（角度制） ---
#60 := ABS(#1 - #2);
#61 := ACOS(0.5);         // 反余弦（角度制）
#62 := ASIN(0.5);          // 反正弦（角度制）
#63 := ATAN(1.0);          // 反正切（角度制，±90°）
#64 := ATAN2(1.0, 1.0);   // 反正切（角度制，含象限判断，±180°）
#65 := COS(180);           // 余弦（角度制）
#66 := SIN(90);            // 正弦（角度制）
#67 := TAN(45);            // 正切（角度制）
#68 := SQRT(144);
#69 := CEIL(3.2);
#70 := FLOOR(3.8);
#71 := ROUND(3.5);
#72 := EXP(1);             // e^1 = 2.71828
#73 := LN(100);            // ln100 = 4.60517
#75 := POW(16, 0.5);      // 16^0.5 = 4
#76 := MAX(3, 5);
#77 := MIN(3, 5);
#78 := SIGN(-5);           // -1
#79 := RANDOM();           // 0~32767 随机整数

// --- 6. 字符串函数 ---
#94 := STR2INT("456");     // 字符串转整数
// SCANTEXT 需要公用变数号码参数
// #96 := SCANTEXT(1);

// --- 7. 变数/资料存取函数 ---
#100 := PARAM(3204);           // 读取 Pr3204
#101 := PARAM(20001, 2);       // 读取 P20001，第二轴群
#102 := SYSVAR(1, 1000);       // 读取第一轴群系统变数 #1000
#103 := SYSDATA(336);          // 读取轴卡交换时间 (D336)
#104 := DRVDATA(1000, 3366);   // 读取第一轴速度命令 (Pn-D26)
// GETARG 读取呼叫者引数 (需在 G65 呼叫的宏程序内使用)
// #105 := GETARG(X);
// GETTRAPARG 读取 Trap 单节内引数
// #106 := GETTRAPARG(X);

// --- 8. 标准单位转换 ---
// #110 := STD(#9, #1600);    // 整数转系统输入单位
// #111 := STDAX(#3, A);      // 整数转轴向标准单位

// --- 9. 文件 I/O ---
// OPEN("PROBE.NC");          // 开启档案
// PRINT("G01 X#3 Y@53");     // 输出字串
// CLOSE();                   // 关闭档案

// --- 10. I/O 控制函数 ---
#130 := READDI(31);            // 读取 DI31
#131 := READDO(11);            // 读取 DO11
SETDO(3, 1);                   // DO3 on
SETDO(8, 0);                   // DO8 off
#132 := READABIT(31);          // 读取 A31
SETABIT(3, 1);                 // A3 on
#134 := READRREGBIT(31, 3);    // 读取 R31 的 Bit3
SETRREGBIT(50, 3, 1);          // R50 的 Bit3 on

// --- 11. XML/Cycle 档案操作函数 ---
// DBOPEN("Test.cyc");              // 开启 Cycle 档案
// #200 := DBOPEN("Test.cyc");
// DBNEW("WarmTest_20220621");      // 新增 Cycle 档案
// DBLOAD(0);                       // 读取第0笔资料
// DBSAVE(0);                       // 覆盖第0笔资料
// DBINSERT(0, "WarmTest");         // 插入 Cycle 资料
// DBDELETE(0);                     // 删除第0笔资料

// --- 12. 图形模拟函数 ---
// #250 := SETDRAW(255, 65280, 5);  // 定义画图样式 (红色路径, 绿色填充, 半径5)
// DRAWHOLE();                      // 画圆

// --- 13. 系统信息/检查函数 ---
ALARM(300);                        // 触发宏程序警报
ALARM(301, "ALARM Content");       // 带内容的警报
MSG(100);                          // 提示ID
MSG("钻头遗失");                    // 提示内容
MSG(100, "钻头遗失");              // 提示ID + 内容
// WAIT();                          // 停止预解
// SLEEP();                         // 放弃执行权 (配合循环使用)
// #260 := CHKMN("5566");           // 检查机械厂代码
// #261 := CHKSN("M9A0001");        // 检查控制器序号
// #262 := CHKMT("MILL");           // 检查机床属性
// #263 := CHKMI("S");              // 检查控制器机型
// #264 := CHKINF(1, "5566");       // 检查类别1 (机械厂代码)
// #265 := AXID(Y);                 // 查询 Y 轴编号 -> 2

// --- 14. 堆栈操作函数 ---
PUSH(#1);                          // 塞入栈
#150 := POP();                     // 取出
#151 := STKTOP[0];                 // 复制(不删除)

// --- 15. 子程序呼叫 ---
// 15.1 G65 单一宏程序呼叫
G65 P1000 L1 X100. Y50. A20.;

// 15.2 G66 模式宏程序呼叫
G66 P1000 L1;
G67;

// 15.3 G66.1 模式宏程序呼叫
G66.1 P1000 L1;
G67;

// 15.4 M98 子程序呼叫
M98 P1000 H2 L1;

// 15.5 M198 子程序呼叫 (另一路径)
M198 P2000 H1;

// 15.6 M99 返回
// M99;

// 15.7 M96/M97 中断程序
M96 P3000 H1;
M97;

// --- 16. 机器人移动指令 ---
// 16.1 MOVJ 关节运动
MOVJ C1=0 C2=0 C3=90 C4=0 C5=0 C6=0 FJ=50 PL=5 ACC=80 DEC=90;

// 16.2 MOVJ-II 关节运动 (末端位置输入)
MOVJ-II X=100. Y=0. Z=50. A=0. B=0. C=0. FJ=50 PL=3;

// 16.3 MOVL 末端直线运动
MOVL X=200. Y=100. Z=50. FL=100. FR=10. PL=3 ACC=80 DEC=90;

// 16.4 MOVC 圆弧运动
MOVC Xp=150. Yp=50. Zp=0. X=200. Y=100. Z=0. FL=100. PL=3;

// 16.5 INCMOVJ 增量关节运动
INCMOVJ C1=10. C2=5. FJ=30 PL=2;

// 16.6 INCMOVL 增量直线运动
INCMOVL X=50. Y=20. Z=10. FL=80. PL=2;

// --- 17. 坐标系指令 ---
// 17.1 用户坐标系
USERCOR P1;

// 17.2 G68.18 设定用户坐标系
G68.18 P1 X10. Y20. Z30. A0. B0. C0.;

// 17.3 工件坐标系 (叠加层)
OBJCORON X5. Y0. Z0. A0. B0. C0.;
OBJCOROFF;
OBJCORCLEAR;

// 17.4 工具坐标系
TOOLCOR T1;
TOOLCORON T2;
TOOLCOROFF;
TOOLCOR CLEAR;

// --- 18. 应用指令 ---
// 18.1 跳脱功能
SKIPCOND E1 Q33 R1 P1;
MOVL X=100. Y=0. Z=0. SKIP;

// 18.2 等待计时
G04.102 I1 X1000;

// 18.3 等待讯号不减速
SWAITSIG P1 Q33 R1 L100 T5000;

// 18.4 进阶输出
SYNCOUT S1 Q1 P50 R1;
MOVL X=100. Y=0. Z=0.;
SYNCOUT S1 Q1 P100 R0;

// 18.5 摆动指令
WEAVEON P1;
WEAVEON E2.0 Q1.0 K45 L100 R0;
WEAVEOFF;

// 18.6 连续脉冲输出
STITCHON S1 Q100 L50 E10.;
STITCHOFF;

// 18.7 坐标转换
POSEMAP X=100. Y=0. Z=50. A=0. B=0. C=0. Q1 R1;

// 18.8 点位偏移
SHIFTON P1 X5. Y0. Z0. A0. B0. C0.;
SHIFTOFF;

// 18.9 末端追踪
G192.1 P1 Q100 R1 E5;
G192.2;

// 18.10 暂停
PAUSE;

// 18.11 加减速度 (单独使用)
ACC 80;
DEC 90;

// --- 19. G 码测试 ---
G00 X0. Y0.;
G01 X100. Y50. F1000.;
G02 X150. Y100. I50. J0.;
G03 X100. Y50. I-50. J0.;
G04 X1000;
G09 X100.;
G10 L1000 R1 100;
G10 L1021 P1 D100;
G10 L1805 O1 R1 J500;
G10 L1900 P1 D100;
G10 L1901 P1 D100;
G10 L1910 P1 D100;
G10 L1911 P1 D100;
G17;
G18;
G19;
G20;
G21;
G28;
G30;
G40;
G41;
G42;
G43;
G49;
G53;
G54;
G55;
G56;
G57;
G58;
G59;
G65 P1000;
G66 P1000;
G67;
G68;
G69;
G90;
G91;
G94;
G95;
G04.1 P1;
G04.102 I1 X100;
G68.18 P1 X10. Y20. Z30.;
G192.1 P1 Q100 R1;
G192.2;

// --- 20. M 码测试 ---
M00;
M01;
M02;
M03 S1000;
M04 S1000;
M05;
M06 T1;
M07;
M08;
M09;
M30;
M96 P3000 H1;
M97;
M98 P1000 H1 L1;
M99;
M198 P2000 H1;

// --- 21. 注释测试 ---
// 单行注释
#200 := 1; // 行尾注释

(*
  多行块注释
  用于测试跨行注释处理
  确保括号匹配不受影响
*)

// --- 22. 中文字符检测 ---
// 注释中的中文是允许的
// 变量赋值不能包含中文
#201 := 100;

// --- 23. 复杂嵌套场景 ---
// 综合测试: 控制流 + 函数 + 运算符
FOR #1 := 1 TO 10 BY 1 DO
  IF #1 > 5 THEN
    #202 := SQRT(POW(#1, 2));
    IF #202 > 7 THEN
      GOTO 300;
    END_IF;
  ELSE
    #202 := #1 * 2;
  END_IF;
END_FOR;

N300;
#203 := 0;

// 综合测试: WHILE + CASE + 机器人指令
WHILE #203 < 10 DO
  CASE #203 OF
    0: MOVJ C1=#203 C2=0 FJ=50;
    1: MOVL X=#203 Y=0. Z=0. FL=100;
    2: INCMOVJ C1=5. FJ=30;
    ELSE: PAUSE;
  END_CASE;
  #203 := #203 + 1;
  SLEEP();
END_WHILE;

M99;