{
  "IF 语句（带 ELSEIF 和 ELSE）": {
    "prefix": "ife",
    "body": [
      "IF ${1:条件} THEN",
      "${2:// 代码}",
      "ELSEIF ${3:条件} THEN",
      "${4:// 代码}",
      "ELSE",
      "${5:// 代码}",
      "END_IF"
    ],
    "description": "IF 条件语句（含 ELSEIF / ELSE）"
  },
  "IF 语句（简化版）": {
    "prefix": "if",
    "body": [
      "IF ${1:条件} THEN",
      "${2:// 代码}",
      "END_IF"
    ],
    "description": "IF 条件语句（仅 IF/END_IF）"
  },
  "FOR 循环": {
    "prefix": "for",
    "body": [
      "FOR ${1:#i} := ${2:1} TO ${3:10} BY ${4:1} DO",
      "${5:// 代码}",
      "END_FOR"
    ],
    "description": "FOR 循环（从起始到终止，步进执行）"
  },
  "WHILE 循环": {
    "prefix": "while",
    "body": [
      "WHILE ${1:条件} DO",
      "${2:// 代码}",
      "END_WHILE"
    ],
    "description": "WHILE 循环（条件为真时重复执行）"
  },
  "REPEAT 循环": {
    "prefix": "repeat",
    "body": [
      "REPEAT",
      "${1:// 代码}",
      "UNTIL ${2:条件}",
      "END_REPEAT"
    ],
    "description": "REPEAT 循环（先执行后判断，必须以 END_REPEAT 结尾）"
  },
  "CASE 选择": {
    "prefix": "case",
    "body": [
      "CASE ${1:#变量} OF",
      "${2:值1}:",
      "\t${3:// 代码}",
      "${4:值2},${5:值3}:",
      "\t${6:// 代码}",
      "ELSE",
      "\t${7:// 代码}",
      "END_CASE;"
    ],
    "description": "CASE 多分支选择语句"
  },
  "GOTO 跳转": {
    "prefix": "goto",
    "body": [
      "GOTO ${1:标签}"
    ],
    "description": "GOTO 跳转到指定标签"
  },
  "G10 L1000 R 寄存器写入": {
    "prefix": "g10l1000",
    "body": [
      "G10 L1000 P${1:1024} R${2:0};"
    ],
    "description": "透过 G 码写入 R 寄存器"
  },
  "G10 L1803 MACRO IO TYPE-1": {
    "prefix": "g10l1803",
    "body": [
      "G10 L1803 I${1:2} Q${2:50} P${3:0.} R${4:1} J${5:0} K${6:0} E${7:0};"
    ],
    "description": "MACRO IO TYPE-1：运动单节内按距离触发 R/O/A 讯号"
  },
  "G10 L1805 MACRO IO TYPE-2": {
    "prefix": "g10l1805",
    "body": [
      "G10 L1805 I${1:2} Q${2:50} R${3:1} J${4:0};"
    ],
    "description": "MACRO IO TYPE-2：单节间触发 R/O/A 讯号"
  },
  "G10 L1810 设定讯号条件": {
    "prefix": "g10l1810",
    "body": [
      "G10 L1810 I${1:2} Q${2:1} R${3:1} J${4:0};"
    ],
    "description": "设定 G10 L1820 讯号等待条件"
  },
  "G10 L1820 等待讯号条件": {
    "prefix": "g10l1820",
    "body": [
      "G10 L1820 P${1:5000} K${2:0};"
    ],
    "description": "等待 G10 L1810 设定的讯号条件成立"
  },
  "G10 L1021 ENIP 通讯": {
    "prefix": "g10l1021",
    "body": [
      "G10 L1021 Q${1:1} P${2:1} S${3:75} C${4:105} I${5:1} X${6:20000} Y${7:0} U${8:20032} V${9:1};"
    ],
    "description": "发送 EtherNet/IP 通讯命令"
  },
  "G10 L1022 EtherCAT 读取": {
    "prefix": "g10l1022r",
    "body": [
      "G10 L1022 P0 A${1:1} I${2:\"2000h\"} U${3:0} R${4:30000};"
    ],
    "description": "EtherCAT 物件字典读取"
  },
  "G10 L1022 EtherCAT 写入": {
    "prefix": "g10l1022w",
    "body": [
      "G10 L1022 P1 A${1:1} I${2:\"2000h\"} U${3:0} B${4:32} V${5:50} E${6:30000};"
    ],
    "description": "EtherCAT 物件字典写入"
  },
  "G10 L1900 Modbus TCP 读取": {
    "prefix": "g10l1900r",
    "body": [
      "G10 L1900 C3 I${1:165} A${2:1000} Q${3:30000} K${4:1};"
    ],
    "description": "Modbus-TCP 读取一至多笔资料"
  },
  "G10 L1900 Modbus TCP 写入": {
    "prefix": "g10l1900w",
    "body": [
      "G10 L1900 C6 I${1:165} A${2:1000} X${3:1995};"
    ],
    "description": "Modbus-TCP 写一笔资料"
  },
  "G10 L1901 Modbus TCP 自定义封包": {
    "prefix": "g10l1901",
    "body": [
      "G10 L1901 P${1:2020} R${2:11} Q${3:30010} K${4:10};"
    ],
    "description": "Modbus-TCP 自定义封包"
  },
  "G10 L1910 Modbus RS485 读取": {
    "prefix": "g10l1910r",
    "body": [
      "G10 L1910 C3 I${1:165} A${2:1000} Q${3:30000} K${4:1};"
    ],
    "description": "Modbus-RS485 读取一至多笔资料"
  },
  "G10 L1910 Modbus RS485 写入": {
    "prefix": "g10l1910w",
    "body": [
      "G10 L1910 C6 I${1:165} A${2:1000} X${3:1995};"
    ],
    "description": "Modbus-RS485 写一笔资料"
  },
  "G10 L1911 Modbus RS485 自定义封包": {
    "prefix": "g10l1911",
    "body": [
      "G10 L1911 P${1:2020} R${2:11} Q${3:30010} K${4:10};"
    ],
    "description": "Modbus-RS485 自定义封包"
  },
  "变量赋值": {
    "prefix": "set",
    "body": [
      "${1:#变量} := ${2:值}"
    ],
    "description": "变量赋值（:=）"
  },
  "带注释赋值": {
    "prefix": "setc",
    "body": [
      "${1:#变量} := ${2:值}  ${3:// 注释说明}"
    ],
    "description": "带注释的变量赋值"
  },
  "完整MACRO程序模板": {
    "prefix": "macro",
    "body": [
      "%@MACRO",
      "",
      "// ===== 程序信息 =====",
      "// 程序名: ${1:程序名称}",
      "// 功能描述: ${2:功能描述}",
      "// 创建日期: ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DAY}",
      "// 作者: ${6:作者}",
      "",
      "// ===== 变量声明 =====",
      "// ${7:// 在此声明局部变量和参数}",
      "",
      "N10;",
      "${8:// 主程序代码}",
      "",
      "M99  // 程序结束返回"
    ],
    "description": "完整的 MACRO 程序模板（含文件头注释）"
  },
  "子程序模板": {
    "prefix": "sub",
    "body": [
      "%@MACRO",
      "",
      "// ===== 子程序 =====",
      "// 子程序名: ${1:子程序名称}",
      "// 参数说明: #1=${2:参数1}, #2=${3:参数2}",
      "",
      "${4:// 子程序代码}",
      "",
      "M99  // 返回主程序"
    ],
    "description": "MACRO 子程序模板"
  },
  "ALARM 报警": {
    "prefix": "alarm",
    "body": [
      "ALARM(${1:报警编号}, \"${2:报警信息}\")"
    ],
    "description": "触发报警（编号 + 提示信息）"
  },
  "MSG 消息提示": {
    "prefix": "msg",
    "body": [
      "MSG(\"${1:提示信息}\")"
    ],
    "description": "屏幕显示消息提示"
  },
  "WAIT 挡预解": {
    "prefix": "wait",
    "body": [
      "WAIT();"
    ],
    "description": "系统停止预解，直到 WAIT 前的指令执行完毕"
  },
  "OPEN 打开文件": {
    "prefix": "open",
    "body": [
      "OPEN(\"${1:文件路径}\")"
    ],
    "description": "打开文件（不指定模式=覆写，\"a\"=附加）"
  },
  "OPEN 附加打开文件": {
    "prefix": "opena",
    "body": [
      "OPEN(\"${1:文件路径}\", \"a\")"
    ],
    "description": "以附加模式打开文件"
  },
  "PRINT 输出字符串": {
    "prefix": "print",
    "body": [
      "PRINT(\"${1:输出字串}\")"
    ],
    "description": "输出字符串到档案或传输埠（变数名会被替换为内容）"
  },
  "CLOSE 关闭文件": {
    "prefix": "close",
    "body": [
      "CLOSE();"
    ],
    "description": "关闭由 OPEN 开启的档案"
  },
  "READDI 读取DI信号": {
    "prefix": "readdi",
    "body": [
      "#${1:变量} := READDI(${2:DI端口号})"
    ],
    "description": "读取数字输入（DI）信号状态"
  },
  "SETDO 设置DO信号": {
    "prefix": "setdo",
    "body": [
      "SETDO(${1:DO端口号}, ${2:0或1})"
    ],
    "description": "设置数字输出（DO）信号"
  },
  "READABIT 读取ABIT": {
    "prefix": "readabit",
    "body": [
      "#${1:变量} := READABIT(${2:点编号})"
    ],
    "description": "读取指定的 A 点编号（0~511）"
  },
  "SETABIT 设置ABIT": {
    "prefix": "setabit",
    "body": [
      "SETABIT(${1:点编号}, ${2:0或1})"
    ],
    "description": "设定指定的 A 点开/关（0~511）"
  },
  "G65 调用宏程序": {
    "prefix": "g65",
    "body": [
      "G65 P${1:宏程序号} L${2:调用次数} A${3:参数1} B${4:参数2}"
    ],
    "description": "G65 调用宏程序（P=程序号, L=次数, A/B/C...=参数传递）"
  },
  "DBOPEN 打开数据库": {
    "prefix": "dbopen",
    "body": [
      "DBOPEN(\"${1:数据库文件名}\")"
    ],
    "description": "打开数据库文件"
  },
  "DBSAVE 保存数据库": {
    "prefix": "dbsave",
    "body": [
      "DBSAVE(${1:Index})"
    ],
    "description": "覆盖第 Index 笔的 Cycle 资料"
  },
  "DBINSERT 插入数据": {
    "prefix": "dbinsert",
    "body": [
      "DBINSERT(${1:Index}, \"${2:Cycle Name}\")"
    ],
    "description": "新增 Cycle 资料到第 Index 笔"
  },
  "DBLOAD 加载数据": {
    "prefix": "dbload",
    "body": [
      "DBLOAD(${1:数据组})"
    ],
    "description": "从数据库加载一条数据"
  },
  "DBDELETE 删除数据": {
    "prefix": "dbdelete",
    "body": [
      "DBDELETE(${1:数据组})"
    ],
    "description": "从数据库删除一条数据"
  },
  "DBNEW 新建数据库": {
    "prefix": "dbnew",
    "body": [
      "DBNEW(\"${1:档案名}\")"
    ],
    "description": "新增并开启全新的 Cycle 档案"
  },
  "SETDRAW 绘图设置": {
    "prefix": "setdraw",
    "body": [
      "SETDRAW(${1:路径颜色}[, ${2:填充颜色}, ${3:刀具半径}])"
    ],
    "description": "定义图形模拟的画图样式"
  },
  "块注释": {
    "prefix": "bc",
    "body": [
      "(* ${1:注释内容} *)"
    ],
    "description": "块注释 (* *)"
  },
  "SYSVAR 系统变量": {
    "prefix": "sysvar",
    "body": [
      "#${1:变量} := SYSVAR(${2:轴群识别码}, ${3:系统变数码})"
    ],
    "description": "读取特定轴群中的系统变数"
  },
  "CHKMN 检查机械厂代码": {
    "prefix": "chkmn",
    "body": [
      "#${1:变量} := CHKMN(\"${2:机械厂代码}\")"
    ],
    "description": "检查机械厂代码是否一致"
  },
  "PARAM 参数读取": {
    "prefix": "param",
    "body": [
      "#${1:变量} := PARAM(${2:参数号码}[, ${3:轴群}])"
    ],
    "description": "读取系统参数 Pr 或 V12 PN 参数"
  },
  "PUSH 压栈": {
    "prefix": "push",
    "body": [
      "PUSH(${1:值})"
    ],
    "description": "将值压入堆栈"
  },
  "POP 出栈": {
    "prefix": "pop",
    "body": [
      "#${1:变量} := POP()"
    ],
    "description": "从堆栈弹出值"
  },
  "MOVJ 关节运动": {
    "prefix": "movj",
    "body": [
      "MOVJ C1=${1:0} C2=${2:0} C3=${3:90} C4=${4:0} C5=${5:0} C6=${6:0} A1=${7:0} FJ${8:50} FEJ${9:100};"
    ],
    "description": "MOVJ 关节运动到指定位置"
  },
  "MOVJ 末端位置语法": {
    "prefix": "movjx",
    "body": [
      "MOVJ X${1:100.} Y${2:0.} Z${3:50.} A${4:0.} B${5:0.} C${6:0.} A1=${7:0} P${8:1} Q${9:1} FJ${10:50} FEJ${11:100};"
    ],
    "description": "MOVJ 第二语法（末端位置输入）"
  },
  "MOVL 直线运动": {
    "prefix": "movl",
    "body": [
      "MOVL X${1:0.} Y${2:0.} Z${3:0.} A${4:0.} B${5:0.} C${6:0.} A1=${7:0} P${8:1} Q${9:1} FL${10:100.} FR${11:10.} FEJ${12:100};"
    ],
    "description": "MOVL 末端直线运动到指定坐标"
  },
  "MOVC 圆弧运动": {
    "prefix": "movc",
    "body": [
      "MOVC X${1:200.} Y${2:100.} Z${3:0.} A${4:0.} B${5:0.} C${6:0.} A1=${7:0} FL${8:100.} FR${9:10.} FEJ${10:100} PL${11:3} ACC${12:80} DEC${13:90};"
    ],
    "description": "MOVC 圆弧运动（经过中间点到终点）"
  },
  "INCMOVJ 增量关节运动": {
    "prefix": "incmovj",
    "body": [
      "INCMOVJ C1=${1:10} C2=${2:5} C3=${3:0} C4=${4:0} C5=${5:0} C6=${6:0} A1=${7:0} Q${8:1} FJ${9:30} FEJ${10:100} PL${11:2} ACC${12:80} DEC${13:90};"
    ],
    "description": "INCMOVJ 增量关节运动"
  },
  "INCMOVL 增量直线运动": {
    "prefix": "incmovl",
    "body": [
      "INCMOVL P${1:1} X${2:50.} Y${3:20.} Z${4:10.} A${5:0.} B${6:0.} C${7:0.} A1=${8:0} Q${9:1} FL${10:80.} FR${11:10.} FEJ${12:100} PL${13:2} ACC${14:80} DEC${15:90};"
    ],
    "description": "INCMOVL 增量直线运动"
  },
  "USERCOR 用户坐标系": {
    "prefix": "usercor",
    "body": [
      "USERCOR P${1:1};"
    ],
    "description": "设定用户坐标系"
  },
  "OBJCORON 工件坐标系开启": {
    "prefix": "objcoron",
    "body": [
      "OBJCORON X${1:0.} Y${2:0.} Z${3:0.} A${4:0.} B${5:0.} C${6:0.};"
    ],
    "description": "开启工件坐标系（叠加层）"
  },
  "TOOLCOR 工具坐标系": {
    "prefix": "toolcor",
    "body": [
      "TOOLCOR P${1:1};"
    ],
    "description": "设定工具坐标系"
  },
  "SKIPCOND 跳脱条件": {
    "prefix": "skipcond",
    "body": [
      "SKIPCOND E${1:1} Q${2:33} R${3:1} P${4:1};"
    ],
    "description": "设定跳脱条件"
  },
  "SWAITSIG 等待讯号": {
    "prefix": "swaitsig",
    "body": [
      "SWAITSIG P${1:1} Q${2:33} R${3:1} L${4:100} T${5:5000};"
    ],
    "description": "等待讯号不减速"
  },
  "SYNCOUT 进阶输出": {
    "prefix": "syncout",
    "body": [
      "SYNCOUT S${1:1} Q${2:1} P${3:50} R${4:1} K${5:0};"
    ],
    "description": "进阶输出指令"
  },
  "WEAVEON 摆动开启": {
    "prefix": "weaveon",
    "body": [
      "WEAVEON P${1:1} E${2:2.0} Q${3:1.0} K${4:45} L${5:100};"
    ],
    "description": "开启摆动指令"
  },
  "PAUSE 暂停": {
    "prefix": "pause",
    "body": [
      "PAUSE;"
    ],
    "description": "暂停程序执行，需人工重启"
  },
  "GETPR 读取参数": {
    "prefix": "getpr",
    "body": [
      "#${1:变量} := GETPR(${2:参数编号});"
    ],
    "description": "读取控制器参数（Pr）"
  },
  "SETPR 写入参数": {
    "prefix": "setpr",
    "body": [
      "SETPR(${1:参数编号}, ${2:值});"
    ],
    "description": "写入控制器参数（Pr）"
  },
  "SLEEP 释放执行权": {
    "prefix": "sleep",
    "body": [
      "SLEEP();"
    ],
    "description": "暂时放弃宏程序循环执行权，释放 CPU 资源（仅在循环中有效）"
  },
  "M198 子程序呼叫": {
    "prefix": "m198",
    "body": [
      "M198 P${1:程序号} H${2:行号} L${3:次数};"
    ],
    "description": "呼叫子程序（另一路径）"
  },
  "G66.1 模式宏程序": {
    "prefix": "g661",
    "body": [
      "G66.1 P${1:宏程序号} L${2:次数};",
      "${3:// 每行运动指令都会调用}",
      "G67;"
    ],
    "description": "G66.1 模式宏程序呼叫（每行运动都调用，G67 取消）"
  }
}
