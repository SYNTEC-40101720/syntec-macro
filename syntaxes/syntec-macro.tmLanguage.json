{
  "name": "Syntec Macro",
  "scopeName": "source.syntec-macro",
  "patterns": [
    {
      "match": "^%@MACRO",
      "name": "keyword.control.header.syntec-macro"
    },
    {
      "match": "//.*$",
      "name": "comment.line.double-slash.syntec-macro"
    },
    {
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "name": "comment.block.stars.syntec-macro"
    },
    {
      "match": "\\b(M99|M30|M02)\\b",
      "name": "keyword.control.end.syntec-macro"
    },
    {
      "match": "\\b(IF|THEN|ELSE|ELSEIF|END_IF|ENDIF)\\b",
      "name": "keyword.control.conditional.syntec-macro"
    },
    {
      "match": "\\b(REPEAT|UNTIL|END_REPEAT|ENDREPEAT)\\b",
      "name": "keyword.control.repeat.syntec-macro"
    },
    {
      "match": "\\b(WHILE|DO|END_WHILE|ENDWHILE)\\b",
      "name": "keyword.control.while.syntec-macro"
    },
    {
      "match": "\\b(FOR|TO|BY|END_FOR|ENDFOR)\\b",
      "name": "keyword.control.for.syntec-macro"
    },
    {
      "match": "\\b(CASE|OF|END_CASE|ENDCASE)\\b",
      "name": "keyword.control.case.syntec-macro"
    },
    {
      "match": "\\b(GOTO|EXIT)\\b",
      "name": "keyword.control.flow.syntec-macro"
    },
    {
      "match": "\\b(MOVJ|MOVJ-II|MOVL|MOVC|INCMOVJ|INCMOVL)\\b",
      "name": "keyword.control.robot-move.syntec-macro"
    },
    {
      "match": "\\b(USERCOR|OBJCORON|OBJCOROFF|OBJCORCLEAR|TOOLCOR|TOOLCORON|TOOLCOROFF)\\b",
      "name": "keyword.control.robot-coord.syntec-macro"
    },
    {
      "match": "\\b(SKIPCOND|SKIP|SWAITSIG|SYNCOUT|WEAVEON|WEAVEOFF|STITCHON|STITCHOFF|POSEMAP|SHIFTON|SHIFTOFF|PAUSE)\\b",
      "name": "keyword.control.robot-app.syntec-macro"
    },
    {
      "match": "\\b(ACC|DEC|FJ|FEJ|FL|FR|PL|PQ|PR)\\b",
      "name": "keyword.operator.robot-param.syntec-macro"
    },
    {
      "match": "\\b(AND|OR|XOR|NOT)\\b|&",
      "name": "keyword.operator.logical.syntec-macro"
    },
    {
      "match": "\\b(MOD|DIV)\\b",
      "name": "keyword.operator.arithmetic.syntec-macro"
    },
    {
      "match": ":=",
      "name": "keyword.operator.assignment.syntec-macro"
    },
    {
      "match": "==|<>|<=|>=|=|<|>",
      "name": "keyword.operator.comparison.syntec-macro"
    },
    {
      "match": "\\b(ABS|ACOS|ASIN|ATAN|ATAN2|COS|SIN|TAN|CEIL|FLOOR|ROUND|SQRT|EXP|LN|POW|MAX|MIN|SIGN|RANDOM)\\b",
      "name": "support.function.math.syntec-macro"
    },
    {
      "match": "\\b(STR2INT|SCANTEXT)\\b",
      "name": "support.function.string.syntec-macro"
    },
    {
      "match": "\\b(OPEN|CLOSE|PRINT|GETARG|GETTRAPARG|PARAM)\\b",
      "name": "support.function.io.syntec-macro"
    },
    {
      "match": "\\b(READDI|READDO|READABIT|SETDO|SETABIT|READRREGBIT|SETRREGBIT)\\b",
      "name": "support.function.io.rw.syntec-macro"
    },
    {
      "match": "\\b(DBOPEN|DBNEW|DBLOAD|DBSAVE|DBINSERT|DBDELETE)\\b",
      "name": "support.function.db.syntec-macro"
    },
    {
      "match": "\\b(ALARM|MSG|WAIT|SLEEP|SYSVAR|SYSDATA|DRVDATA|STD|STDAX)\\b",
      "name": "support.function.system.syntec-macro"
    },
    {
      "match": "\\b(CHKMN|CHKSN|CHKMT|CHKMI|CHKINF)\\b",
      "name": "support.function.check.syntec-macro"
    },
    {
      "match": "\\b(PUSH|POP|STKTOP|AXID)\\b",
      "name": "support.function.misc.syntec-macro"
    },
    {
      "match": "\\b(SETDRAW|DRAWHOLE)\\b",
      "name": "support.function.draw.syntec-macro"
    },
    {
      "match": "@\\d+|@\\[[^\\]]+\\]",
      "name": "variable.language.global.syntec-macro"
    },
    {
      "match": "#\\[[^\\]]+\\]|#[1-9]\\d*",
      "name": "variable.language.local.syntec-macro"
    },
    {
      "match": "\\b(?:AR|MAR)(?:\\d+|\\[[^\\]]+\\])",
      "name": "variable.language.app.syntec-macro"
    },
    {
      "match": "\\$[1-4]\\b",
      "name": "variable.language.axis-group.syntec-macro"
    },
    {
      "match": "\\bG\\d+(?:\\.\\d+)?\\b",
      "name": "entity.name.function.gcode.syntec-macro"
    },
    {
      "match": "\\bM\\d+\\b",
      "name": "entity.name.function.mcode.syntec-macro"
    },
    {
      "match": "\\bM#\\d+\\b",
      "name": "entity.name.function.mcode.dynamic.syntec-macro"
    },
    {
      "match": "^\\s*N\\d+\\s*;",
      "name": "entity.name.label.syntec-macro"
    },
    {
      "match": "\\bG65(?:\\.1)?\\b",
      "name": "keyword.other.call.syntec-macro"
    },
    {
      "match": "\\bG66(?:\\.1)?\\b",
      "name": "keyword.other.modal-call.syntec-macro"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.syntec-macro"
    },
    {
      "match": "\\b\\d+\\.\\d*\\b",
      "name": "constant.numeric.float.syntec-macro"
    },
    {
      "match": "\\b\\d+\\b",
      "name": "constant.numeric.integer.syntec-macro"
    }
  ]
}