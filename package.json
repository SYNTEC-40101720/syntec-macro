{
  "name": "syntec-macro",
  "displayName": "SYNTEC 宏程序",
  "description": "为新代（Syntec）CNC 宏程序提供语法高亮、智能补全、悬停文档、G/M代码跳转、实时语法检查",
  "icon": "images/icon.png",
  "version": "2.11.3",
  "publisher": "syntec-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/SYNTEC-40101720/syntec-macro"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:syntec-macro"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "syntec-macro",
        "aliases": [
          "Syntec 新代宏程序",
          "Syntec Macro",
          "syntec-macro"
        ],
        "extensions": [
          ".nc",
          ".cnc",
          ".tap",
          ".prt",
          ".mpf",
          ".ptp",
          ".pim",
          ".anc",
          ".bj",
          ".edit",
          ".demo"
        ],
        "firstLine": "^%@MACRO"
      }
    ],
    "grammars": [
      {
        "language": "syntec-macro",
        "scopeName": "source.syntec-macro",
        "path": "./syntaxes/syntec-macro.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "syntec-macro",
        "path": "./snippets/syntec-macro.json"
      }
    ],
    "configurationDefaults": {
      "[syntec-macro]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": false,
        "editor.autoIndent": "advanced",
        "editor.colorDecorators": false,
        "editor.defaultColorDecorators": "never",
        "editor.colorDecoratorsActivatedOn": "never"
      }
    },
    "configuration": {
      "title": "Syntec 宏程序设置",
      "properties": {
        "syntecMacro.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "启用语法诊断（IF/END_IF 配对、括号匹配）"
        },
        "syntecMacro.enableCompletions": {
          "type": "boolean",
          "default": true,
          "description": "启用函数和关键字补全"
        },
        "syntecMacro.enableHover": {
          "type": "boolean",
          "default": true,
          "description": "启用悬停文档"
        },
        "syntecMacro.includePath": {
          "type": "array",
          "default": [],
          "description": "G65 宏程序文件额外搜索路径（绝对路径）",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "test": "npm run docs:diagnostics:check && npm run check:release && npm run check:vsix && node tests/validator.test.js && node --test tests/releaseConsistency.test.js tests/vsixContents.test.js tests/extension.test.js",
    "test:integration": "node tests/integration/runTest.js",
    "test:integration:navigation": "node tests/integration/runTest.js --navigation-benchmark",
    "smoke:installed": "node scripts/runInstalledSmoke.js",
    "benchmark:navigation": "node scripts/benchmarkNavigation.js",
    "docs:diagnostics": "node scripts/generateDiagnosticDocs.js",
    "docs:diagnostics:check": "node scripts/generateDiagnosticDocs.js --check",
    "check:release": "node scripts/checkReleaseConsistency.js",
    "check:vsix": "node scripts/checkVsixContents.js",
    "package": "npm run check:vsix && vsce package --allow-star-activation && node scripts/reportVsixArtifact.js",
    "lint": "npx eslint src/ scripts/ tests/"
  },
  "devDependencies": {
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "eslint": "^10.4.0"
  }
}
